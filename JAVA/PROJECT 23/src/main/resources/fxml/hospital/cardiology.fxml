<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.project.hospitalmanagementsystem.controller.hospital.Cardiology" alignment="TOP_CENTER" styleClass="department-root">
    <Label text="Cardiology Department" styleClass="department-header" />

    <TextArea editable="false" wrapText="true" styleClass="overview-text" text="Heart-related diagnosis, treatment, and monitoring including ECG, echocardiograms, and stress testing."/>

    <Label text="Services Offered:" styleClass="section-title" />
    <VBox spacing="5" styleClass="services-list" alignment="CENTER">
        <Label text="• Electrocardiogram (ECG)"/>
        <Label text="• Echocardiograms"/>
        <Label text="• Cardiac Stress Testing"/>
        <Label text="• Holter Monitoring"/>
    </VBox>

    <Label text="Doctors" styleClass="section-title"/>
    <FlowPane fx:id="doctorPane" hgap="20" vgap="20" prefWrapLength="600" alignment="CENTER"/>

    <Label text="Working Hours: Mon - Fri, 08:00 - 17:00" styleClass="hours-label"/>

    <HBox spacing="20" alignment="BOTTOM_CENTER" styleClass="nav-bar">
        <Button text="← Back" onAction="#handleBack" styleClass="nav-button"/>
        <Button fx:id="bookButton" text="Appointments" onMouseClicked="#handleBookAppointment" styleClass="nav-button"/>
    </HBox>


</VBox>
