<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.project.hospitalmanagementsystem.controller.hospital.Neurology"
            prefWidth="800" prefHeight="600">

    <VBox spacing="15"
          alignment="TOP_CENTER"
          AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
          styleClass="department-root">
        <padding><Insets top="10"/> </padding>


        <Label text="Neurology Department" styleClass="department-header"/>

        <TextArea editable="false" wrapText="true" styleClass="overview-text"
                  text="Diagnosis and treatment of nervous system disorders including epilepsy, stroke, and neuropathies."/>

        <Label text="Services Offered:" styleClass="section-title" />
        <VBox spacing="5" styleClass="services-list" alignment="CENTER">
            <Label text="• Epilepsy Management"/>
            <Label text="• Stroke Care"/>
            <Label text="• Neuropathy Treatment"/>
        </VBox>

        <Label text="Doctors" styleClass="section-title" />
        <FlowPane fx:id="doctorPane" hgap="20" vgap="20" prefWrapLength="700" alignment="CENTER"/>

        <Label text="Working Hours: Mon - Fri, 08:30 - 16:30" styleClass="hours-label"/>
        <HBox spacing="20" alignment="BOTTOM_CENTER" styleClass="nav-bar">
        <Button text="Book Appointment" fx:id="bookButton" styleClass="primary-button"/>
        <Button text="← Back" onAction="#handleBack" styleClass="primary-button" />
        </HBox>

   </VBox>
</AnchorPane>
